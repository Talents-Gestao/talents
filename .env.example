# =============================================================================
# Coolify / produção
# =============================================================================
# - No Coolify: crie o recurso com Docker Compose e aponte para docker-compose.prod.yml
#   (diretório base: pasta onde está este arquivo).
# - Defina APP_KEY (php artisan key:generate), APP_URL com https://, DB_* iguais ao Postgres
#   do stack ou ao banco gerenciado pelo Coolify.
# - DB_HOST e REDIS_HOST nos serviços do compose: use "postgres" e "redis" (nomes dos serviços).
# - APP_ENV=production, APP_DEBUG=false, LOG_LEVEL=error (recomendado).
# - HTTPS: SESSION_SECURE_COOKIE=true, SESSION_SAME_SITE=lax (ou strict).
# - Mail: configure MAIL_* para alertas reais (não use "log" em produção).
# =============================================================================
# Docker local (desenvolvimento) — rodar tudo só dentro do Docker
# =============================================================================
# Subir stack:     docker compose up -d --build
# Composer/PHP:    docker compose exec app composer install
# Artisan:         docker compose exec app php artisan migrate
#                  docker compose exec app php artisan db:seed
# NPM (build):     docker compose --profile tools run --rm node npm ci
#                  docker compose --profile tools run --rm node npm run build
# Não use PHP/Composer/npm do host com DB_HOST=postgres — use sempre os containers.
# =============================================================================

APP_NAME=Talents
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker: use host "postgres" | Local PHP: use 127.0.0.1
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=talents
DB_USERNAME=talents
DB_PASSWORD=secret

# Sessão: redis reduz latência vs database (cada request deixa de ir à BD).
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_WARNING_MINUTES=5
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Produção com HTTPS (Coolify):
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=talents

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@talents.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Hot reload (Vite HMR) — só desenvolvimento local com `docker compose --profile dev up vite`
# A app continua em APP_URL (ex.: http://localhost:8080); assets vêm da porta abaixo.
VITE_DEV_SERVER_URL=http://localhost:5173
VITE_DEV_SERVER_PORT=5173
VITE_HMR_HOST=localhost
# true = necessário no Docker for Windows/macOS (volumes); false se npm run dev nativo no host
VITE_USE_POLLING=true

# Calendário estratégico — limite por anexo (KB; 524288 = 512 MB)
STRATEGIC_CALENDAR_MAX_ATTACHMENT_KB=524288

# Módulo Entrevistas (IA) — upload de áudio e transcrição Whisper
INTERVIEW_MAX_UPLOAD_MB=500
INTERVIEW_KEEP_AUDIO=true
INTERVIEW_WHISPER_MODEL=whisper-1
INTERVIEW_SEGMENT_SECONDS=600

# ReceitaWS API Comercial (consulta CNPJ no cadastro de empresa — não commite o token real)
RECEITAWS_TOKEN=
# RECEITAWS_BASE_URL=https://receitaws.com.br/v1
# RECEITAWS_TIMEOUT=60

APP_PORT=8080
FORWARD_DB_PORT=5433
FORWARD_REDIS_PORT=6380

# RHID (Control iD) — opcional; credenciais ficam por empresa no banco
# RHID_BASE_URL=https://www.rhid.com.br/v2
# RHID_HTTP_TIMEOUT=60
# RHID_REPORT_TIMEOUT=180
# RHID_TOKEN_CACHE_TTL=12600
# RHID_BANK_HOURS_AGGREGATE=false
# Em local, colaboradores fictícios já aparecem se o RHID da empresa não estiver configurado.
# Em staging/prod, force com RHID_DEMO_PERSONS=true (só quando não houver RHID configurado).
# RHID_DEMO_PERSONS=true
# Tolerância (min) usada na aderência espelho vs escala quando o JSON salvo não trouxer tolerancia_minutos (padrão 10).
# RHID_DEFAULT_SCHEDULE_TOLERANCE_MINUTES=10
#
# Solides API (configuração global no admin)
# SOLIDES_BASE_URL=https://app.solides.com
# SOLIDES_LOCALE=pt-BR
# SOLIDES_HTTP_TIMEOUT=30
# SOLIDES_GROUPED_MAX_CURRICULO_PAGES=50
# SOLIDES_GROUPED_HTTP_TIMEOUT=90
#
# Parser PDF do espelho (import local): precisa de Python + pymupdf/pdfplumber no servidor.
# Imagem Docker: ja instala via docker/Dockerfile. Em Coolify sem Docker, instale python3 e:
#   pip install -r tools/rhid-espelho-parser/requirements.txt
# Se `python` nao existir (so python3), defina caminho absoluto:
# RHID_ESPELHO_PYTHON=/usr/bin/python3

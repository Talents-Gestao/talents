# =============================================================================
# Coolify / produção
# =============================================================================
# - No Coolify: crie o recurso com Docker Compose e aponte para docker-compose.prod.yml
#   (diretório base: pasta onde está este arquivo).
# - Defina APP_KEY (php artisan key:generate), APP_URL com https://, DB_* iguais ao Postgres
#   do stack ou ao banco gerenciado pelo Coolify.
# - DB_HOST e REDIS_HOST nos serviços do compose: use "postgres" e "redis" (nomes dos serviços).
# - APP_ENV=production, APP_DEBUG=false, LOG_LEVEL=error (recomendado).
# - HTTPS: SESSION_SECURE_COOKIE=true, SESSION_SAME_SITE=lax (ou strict).
# - Mail: configure MAIL_* para alertas reais (não use "log" em produção).
# =============================================================================
# Docker local (desenvolvimento) — rodar tudo só dentro do Docker
# =============================================================================
# Subir stack:     docker compose up -d --build
# Composer/PHP:    docker compose exec app composer install
# Artisan:         docker compose exec app php artisan migrate
#                  docker compose exec app php artisan db:seed
# NPM (build):     docker compose --profile tools run --rm node npm ci
#                  docker compose --profile tools run --rm node npm run build
# Não use PHP/Composer/npm do host com DB_HOST=postgres — use sempre os containers.
# =============================================================================

APP_NAME=Talents
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker: use host "postgres" | Local PHP: use 127.0.0.1
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=talents
DB_USERNAME=talents
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Produção com HTTPS (Coolify):
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=talents

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@talents.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ReceitaWS API Comercial (consulta CNPJ no cadastro de empresa — não commite o token real)
RECEITAWS_TOKEN=
# RECEITAWS_BASE_URL=https://receitaws.com.br/v1
# RECEITAWS_TIMEOUT=60

APP_PORT=8080
FORWARD_DB_PORT=5433
FORWARD_REDIS_PORT=6380

# RHID (Control iD) — opcional; credenciais ficam por empresa no banco
# RHID_BASE_URL=https://www.rhid.com.br/v2
# RHID_HTTP_TIMEOUT=60
# RHID_REPORT_TIMEOUT=180
# RHID_TOKEN_CACHE_TTL=12600
